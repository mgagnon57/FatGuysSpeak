<UserControl x:Class="FatGuysSpeak.ClientInstaller.Pages.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d0d0d">
    <Grid Margin="28,20,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Welcome"
                   FontFamily="Segoe UI"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#e8e8e8"/>

        <Rectangle Grid.Row="1" Height="1" Fill="#252525" Margin="0,12,0,14"/>

        <StackPanel Grid.Row="2" VerticalAlignment="Top">
            <TextBlock Text="FatGuysSpeak Client"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#e8e8e8"
                       Margin="0,0,0,8"/>

            <TextBlock TextWrapping="Wrap"
                       LineHeight="20"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       Foreground="#888888">
                <Run>This will install the FatGuysSpeak desktop client on your computer.</Run>
            </TextBlock>

            <TextBlock TextWrapping="Wrap"
                       LineHeight="20"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       Foreground="#888888"
                       Margin="0,12,0,0">
                <Run>After installation, launch the app and enter your server address on the login screen to connect.</Run>
            </TextBlock>

            <!-- Feature list -->
            <Border Background="#141414" BorderBrush="#252525" BorderThickness="1"
                    CornerRadius="4" Padding="16,14" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="WHAT'S INCLUDED"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#555555"
                               Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock Text="●" Foreground="#f04010" FontSize="8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Real-time text chat with reactions and replies" FontFamily="Segoe UI" FontSize="12" Foreground="#aaaaaa"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock Text="●" Foreground="#f04010" FontSize="8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Push-to-talk voice with Opus audio encoding" FontFamily="Segoe UI" FontSize="12" Foreground="#aaaaaa"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                        <TextBlock Text="●" Foreground="#f04010" FontSize="8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Screen sharing and webcam streaming" FontFamily="Segoe UI" FontSize="12" Foreground="#aaaaaa"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="●" Foreground="#f04010" FontSize="8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Whisper speech-to-text transcription" FontFamily="Segoe UI" FontSize="12" Foreground="#aaaaaa"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <TextBlock Grid.Row="3"
                   Text="Click Next to continue."
                   FontFamily="Segoe UI"
                   FontSize="11"
                   Foreground="#444444"
                   Margin="0,12,0,0"/>
    </Grid>
</UserControl>
