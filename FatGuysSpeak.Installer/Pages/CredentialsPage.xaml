<UserControl x:Class="FatGuysSpeak.Installer.Pages.CredentialsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d0d0d">
    <StackPanel Margin="40,32,40,24">

        <TextBlock Text="Admin Account" FontSize="22" FontWeight="SemiBold" Foreground="#e8e8e8"/>
        <TextBlock Text="These credentials protect the server dashboard at /metrics"
                   FontSize="12" Foreground="#666666" Margin="0,6,0,0"/>

        <!-- Divider -->
        <Rectangle Fill="#1e1e1e" Height="1" Margin="0,16,0,20"/>

        <!-- Username -->
        <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
        <TextBox x:Name="TxtUsername" Text="admin" MaxLength="50" Margin="0,0,0,16"/>

        <!-- Password -->
        <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
        <PasswordBox x:Name="PwdPassword" PasswordChanged="Pwd_Changed" Margin="0,0,0,16"/>

        <!-- Confirm -->
        <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource FieldLabel}"/>
        <PasswordBox x:Name="PwdConfirm" PasswordChanged="Pwd_Changed"/>

        <!-- Error -->
        <Border x:Name="ErrorBorder" Background="#1a0808" BorderBrush="#5a1a1a"
                BorderThickness="1" CornerRadius="3" Padding="10,7"
                Margin="0,14,0,0" Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="#e05555" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Note -->
        <TextBlock Margin="0,20,0,0"
                   Text="Keep these credentials safe. They grant full control over the server, including user management and channel moderation."
                   Foreground="#555555" FontSize="11" TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
