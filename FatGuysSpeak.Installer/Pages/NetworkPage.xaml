<UserControl x:Class="FatGuysSpeak.Installer.Pages.NetworkPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d0d0d">
    <StackPanel Margin="40,32,40,24">

        <TextBlock Text="Network Configuration" FontSize="22" FontWeight="SemiBold" Foreground="#e8e8e8"/>
        <TextBlock Text="Choose the port the server listens on"
                   FontSize="12" Foreground="#666666" Margin="0,6,0,0"/>

        <Rectangle Fill="#1e1e1e" Height="1" Margin="0,16,0,20"/>

        <!-- Port row -->
        <TextBlock Text="PORT" Style="{StaticResource FieldLabel}"/>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtPort" Text="5238" Grid.Column="0"/>
            <Button x:Name="BtnTest" Content="Test" Grid.Column="2"
                    Style="{StaticResource NavButton}" Padding="14,7"
                    Click="TestPort_Click"/>
            <TextBlock x:Name="PortStatus" Grid.Column="3"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       FontSize="12" Foreground="#555555" Text=""/>
        </Grid>

        <!-- Detected IPs -->
        <Border Background="#111111" BorderBrush="#1e1e1e" BorderThickness="1"
                CornerRadius="3" Padding="14,12" Margin="0,14,0,0">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LAN IP" Foreground="#555555" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtLocalIp" Grid.Column="1" FontSize="13"
                               Foreground="#cccccc" VerticalAlignment="Center" Text="Detecting..."/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Public IP" Foreground="#555555" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtPublicIp" Grid.Column="1" FontSize="13"
                               Foreground="#cccccc" VerticalAlignment="Center" Text="Detecting..."/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Firewall checkbox -->
        <CheckBox x:Name="ChkFirewall" IsChecked="True" Margin="0,18,0,0"
                  Foreground="#cccccc" FontSize="13" Checked="Chk_Changed" Unchecked="Chk_Changed">
            <TextBlock TextWrapping="Wrap">
                <Run Text="Add Windows Firewall inbound rule for port "/>
                <Run x:Name="FirewallPortRun" Text="5238"/>
            </TextBlock>
        </CheckBox>

        <!-- Router note -->
        <Border Background="#0f0f0a" BorderBrush="#2a2a10" BorderThickness="1"
                CornerRadius="3" Padding="12,10" Margin="0,16,0,0">
            <TextBlock Foreground="#888855" FontSize="11" TextWrapping="Wrap"
                       Text="For clients outside your local network, you will also need to forward this port on your router to your LAN IP. Check your router's manual for port forwarding instructions."/>
        </Border>

        <!-- Error -->
        <Border x:Name="ErrorBorder" Background="#1a0808" BorderBrush="#5a1a1a"
                BorderThickness="1" CornerRadius="3" Padding="10,7"
                Margin="0,12,0,0" Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="#e05555" FontSize="12" TextWrapping="Wrap"/>
        </Border>

    </StackPanel>
</UserControl>
