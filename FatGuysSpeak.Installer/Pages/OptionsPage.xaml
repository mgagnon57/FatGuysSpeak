<UserControl x:Class="FatGuysSpeak.Installer.Pages.OptionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d0d0d">
    <StackPanel Margin="28,20,28,16">

        <TextBlock Text="Installation Options" FontSize="22" FontWeight="SemiBold" Foreground="#e8e8e8"/>
        <TextBlock Text="Choose where to install and how the server runs"
                   FontSize="12" Foreground="#666666" Margin="0,6,0,0"/>

        <Rectangle Fill="#1e1e1e" Height="1" Margin="0,12,0,14"/>

        <!-- Install path -->
        <TextBlock Text="INSTALL LOCATION" Style="{StaticResource FieldLabel}"/>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtPath" Text="C:\Program Files\FatGuysSpeak\Server"/>
            <Button Grid.Column="2" Content="Browse" Style="{StaticResource NavButton}"
                    Padding="14,7" Click="Browse_Click"/>
        </Grid>

        <!-- How should the server run? -->
        <TextBlock Text="HOW SHOULD THE SERVER RUN?" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>

        <!-- Mode cards — side by side -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Standalone card -->
            <Border x:Name="StandaloneCard" Grid.Column="0"
                    CornerRadius="4" Padding="12,10"
                    Cursor="Hand" MouseDown="Standalone_Click"
                    BorderThickness="1">
                <Border.Background><SolidColorBrush Color="#141414"/></Border.Background>
                <Border.BorderBrush><SolidColorBrush x:Name="StandaloneBorder" Color="#f04010"/></Border.BorderBrush>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="RadioStandalone" GroupName="RunMode" IsChecked="True"
                                 VerticalAlignment="Top" Margin="0,2,10,0"
                                 Checked="RadioStandalone_Checked"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Standalone" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Launch manually" FontSize="11" Foreground="#888888" Margin="0,2,0,0"/>
                        <TextBlock FontSize="11" Foreground="#666666" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="You start and stop the server yourself. Best for home use, game nights, or testing."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Windows Service card -->
            <Border x:Name="ServiceCard" Grid.Column="2"
                    CornerRadius="4" Padding="12,10"
                    Cursor="Hand" MouseDown="Service_Click"
                    BorderThickness="1">
                <Border.Background><SolidColorBrush Color="#141414"/></Border.Background>
                <Border.BorderBrush><SolidColorBrush x:Name="ServiceBorder" Color="#252525"/></Border.BorderBrush>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="RadioService" GroupName="RunMode" IsChecked="False"
                                 VerticalAlignment="Top" Margin="0,2,10,0"
                                 Checked="RadioService_Checked"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Windows Service" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="Starts automatically at boot" FontSize="11" Foreground="#888888" Margin="0,2,0,0"/>
                        <TextBlock FontSize="11" Foreground="#666666" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="Runs in the background even when no user is logged in. Best for a dedicated always-on machine."/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- Error -->
        <Border x:Name="ErrorBorder" Background="#1a0808" BorderBrush="#5a1a1a"
                BorderThickness="1" CornerRadius="3" Padding="10,7"
                Margin="0,10,0,0" Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="#e05555" FontSize="12" TextWrapping="Wrap"/>
        </Border>

    </StackPanel>
</UserControl>
