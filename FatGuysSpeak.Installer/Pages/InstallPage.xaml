<UserControl x:Class="FatGuysSpeak.Installer.Pages.InstallPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0d0d0d">
    <Grid>

        <!-- Installing view -->
        <StackPanel x:Name="InstallingView" Margin="40,60,40,24" VerticalAlignment="Top">
            <TextBlock Text="Installing..." FontSize="22" FontWeight="SemiBold" Foreground="#e8e8e8"/>
            <TextBlock x:Name="StatusText" Text="Preparing..."
                       FontSize="12" Foreground="#666666" Margin="0,6,0,0"/>
            <ProgressBar x:Name="Progress" Height="4" Margin="0,20,0,0"
                         Background="#1e1e1e" Foreground="#f04010"
                         BorderThickness="0" Minimum="0" Maximum="100"/>
        </StackPanel>

        <!-- Complete view -->
        <StackPanel x:Name="CompleteView" Margin="40,40,40,24" Visibility="Collapsed">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="✓" FontSize="26" Foreground="#36b864" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="Installation Complete" FontSize="22" FontWeight="SemiBold"
                           Foreground="#e8e8e8" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="FatGuysSpeak Server is ready to run."
                       FontSize="12" Foreground="#666666" Margin="0,4,0,0"/>

            <Rectangle Fill="#1e1e1e" Height="1" Margin="0,18,0,16"/>

            <!-- URL info -->
            <Border Background="#111111" BorderBrush="#1e1e1e" BorderThickness="1"
                    CornerRadius="3" Padding="14,12" Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Dashboard" Foreground="#555555" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtDashboardUrl" Grid.Column="1" FontSize="13"
                                   Foreground="#f04010" VerticalAlignment="Center"
                                   TextDecorations="Underline" Cursor="Hand"
                                   MouseDown="DashUrl_Click"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Client URL (LAN)" Foreground="#555555" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLanUrl" Grid.Column="1" FontSize="13"
                                   Foreground="#cccccc" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid x:Name="PublicRow">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Client URL (Internet)" Foreground="#555555" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtPublicUrl" Grid.Column="1" FontSize="13"
                                   Foreground="#cccccc" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Launch note -->
            <TextBlock x:Name="LaunchNote" FontSize="11" Foreground="#555555"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button x:Name="BtnLaunch" Content="Launch Dashboard"
                        Style="{StaticResource GreenButton}" Click="Launch_Click"
                        Margin="0,0,10,0"/>
                <Button x:Name="BtnClose" Content="Close"
                        Style="{StaticResource NavButton}" Click="Close_Click"/>
            </StackPanel>

            <!-- Error from install -->
            <Border x:Name="ErrorBorder" Background="#1a0808" BorderBrush="#5a1a1a"
                    BorderThickness="1" CornerRadius="3" Padding="10,7"
                    Margin="0,12,0,0" Visibility="Collapsed">
                <TextBlock x:Name="ErrorText" Foreground="#e05555" FontSize="12" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

    </Grid>
</UserControl>
