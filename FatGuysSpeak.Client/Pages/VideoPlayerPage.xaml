<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatGuysSpeak.Client.Pages.VideoPlayerPage"
             BackgroundColor="#1a1a2e">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Title bar -->
        <Border Grid.Row="0" BackgroundColor="#16213e" StrokeThickness="0">
            <Label x:Name="TitleLabel" TextColor="#d0d0d0" FontSize="13"
                   Padding="16,10" LineBreakMode="TailTruncation" MaxLines="1" />
        </Border>

        <!-- Embedded player -->
        <WebView Grid.Row="1" x:Name="VideoWebView" />

        <!-- Action bar -->
        <Border Grid.Row="2" BackgroundColor="#16213e" StrokeThickness="0">
            <HorizontalStackLayout Spacing="10" Padding="16,10" HorizontalOptions="End">
                <Button Text="Open in Browser"
                        BackgroundColor="#3a3a5a" TextColor="#d0d0d0"
                        CornerRadius="6" FontSize="13"
                        Clicked="OnOpenInBrowser" />
            </HorizontalStackLayout>
        </Border>

    </Grid>
</ContentPage>
