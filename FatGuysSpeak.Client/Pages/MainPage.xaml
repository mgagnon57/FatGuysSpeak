<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shared="clr-namespace:FatGuysSpeak.Shared;assembly=FatGuysSpeak.Shared"
             xmlns:vm="clr-namespace:FatGuysSpeak.Client.ViewModels"
             xmlns:svc="clr-namespace:FatGuysSpeak.Client.Services"
             xmlns:controls="clr-namespace:FatGuysSpeak.Client.Controls"
             x:Class="FatGuysSpeak.Client.Pages.MainPage"
             x:Name="RootPage"
             Title="FatGuysSpeak"
             BackgroundColor="{DynamicResource ThemeBgPrimary}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:StringToBoolConverter  x:Key="StringToBoolConverter"  xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:InvertBoolConverter    x:Key="InvertBoolConverter"    xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:InitialsConverter      x:Key="InitialsConverter"      xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:MuteButtonConverter    x:Key="MuteButtonConverter"    xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:DeafenButtonConverter  x:Key="DeafenButtonConverter"  xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:MutedBgConverter       x:Key="MutedBgConverter"       xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:SelectedFontConverter  x:Key="SelectedFontConverter"  xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:ChannelSelectionConverter x:Key="ChannelSelectionConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:ChannelTextConverter   x:Key="ChannelTextConverter"   xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:NullToBoolConverter    x:Key="NullToBoolConverter"    xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:TabBgConverter         x:Key="TabBgConverter"         xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:LoopbackColorConverter x:Key="LoopbackColorConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:MicLevelColorConverter x:Key="MicLevelColorConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:UtcToLocalTimeConverter x:Key="UtcToLocalTimeConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:MentionBgConverter     x:Key="MentionBgConverter"     xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:UnreadBadgeBgConverter x:Key="UnreadBadgeBgConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:ReactionBgConverter    x:Key="ReactionBgConverter"    xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:ReactionStrokeConverter x:Key="ReactionStrokeConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:StatusDotColorConverter x:Key="StatusDotColorConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
            <local:ActiveButtonTextColorConverter x:Key="ActiveButtonTextColorConverter" xmlns:local="clr-namespace:FatGuysSpeak.Client"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- ═══ TOP BAR ═══ -->
        <Grid Grid.Row="0" BackgroundColor="{DynamicResource ThemeBgPanel}" Padding="10,6"
              ColumnDefinitions="Auto,Auto,Auto,*">
            <!-- Brand lives in its own Auto column so the connection status can never squeeze it -->
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Border BackgroundColor="{DynamicResource ThemeAccent}" StrokeThickness="0"
                        StrokeShape="RoundRectangle 6" Padding="6,2" VerticalOptions="Center">
                    <Label Text="FGS" FontFamily="Bebas" CharacterSpacing="1" TextColor="White"
                           FontSize="13" FontAttributes="Bold" VerticalOptions="Center" />
                </Border>
                <Label Text="FatGuysSpeak" FontFamily="Bebas" CharacterSpacing="1" TextColor="{DynamicResource ThemeTextPrimary}"
                       FontSize="17" VerticalOptions="Center" LineBreakMode="NoWrap" />
            </HorizontalStackLayout>
            <!-- Connection status -->
            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center" Margin="8,0,0,0">
                <BoxView WidthRequest="1" HeightRequest="14" BackgroundColor="{DynamicResource ThemeBgElevated}" VerticalOptions="Center" />
                <Ellipse WidthRequest="8" HeightRequest="8" Fill="{Binding ConnectionDotColor}" VerticalOptions="Center" />
                <Label Text="{Binding ConnectionStatusText}" TextColor="{Binding ConnectionStatusColor}"
                       FontSize="11" VerticalOptions="Center" LineBreakMode="NoWrap" />
            </HorizontalStackLayout>
            <!-- Online count (invite + DMs moved to the bottom user bar) -->
            <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center" Margin="10,0,0,0">
                <BoxView WidthRequest="1" HeightRequest="14" BackgroundColor="{DynamicResource ThemeBgElevated}" VerticalOptions="Center" />
                <Label Text="{Binding Members.Count, StringFormat='{0} online'}"
                       TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" VerticalOptions="Center"
                       IsVisible="{Binding IsNotDmMode}" />
            </HorizontalStackLayout>
            <!-- Current channel — the flexible column that yields/truncates, never the title -->
            <Label Grid.Column="3"
                   Text="{Binding SelectedChannel.Name, StringFormat='  /  # {0}', FallbackValue=''}"
                   TextColor="{DynamicResource ThemeTextSecondary}" FontSize="12" VerticalOptions="Center"
                   LineBreakMode="TailTruncation" />
        </Grid>

        <!-- ═══ RECONNECT BANNER ═══ -->
        <Grid Grid.Row="1" BackgroundColor="#3d2800" Padding="12,6"
              ColumnDefinitions="Auto,*"
              IsVisible="{Binding IsConnectionBannerVisible}">
            <Label Grid.Column="0" Text="⚠" FontSize="13" TextColor="{Binding ConnectionDotColor}"
                   VerticalOptions="Center" Margin="0,0,8,0" />
            <Label Grid.Column="1" Text="{Binding ConnectionStatusText, StringFormat='Server connection {0}. Voice and messaging are unavailable until reconnected.'}"
                   TextColor="{DynamicResource ThemeWarning}" FontSize="11" VerticalOptions="Center" />
        </Grid>

        <!-- ═══ VERSION MISMATCH BANNER ═══ -->
        <VerticalStackLayout Grid.Row="2">
            <Grid IsVisible="{Binding VersionMismatch}" ColumnDefinitions="*,Auto" BackgroundColor="#3a2a00" Padding="12,6">
                <Label Grid.Column="0" VerticalOptions="Center" TextColor="{DynamicResource ThemeWarning}" Text="{Binding VersionMismatchText}" />
                <Button Grid.Column="1" Text="✕" Command="{Binding DismissMismatchCommand}"
                        BackgroundColor="Transparent" TextColor="{DynamicResource ThemeWarning}" Padding="6,2" />
            </Grid>
        </VerticalStackLayout>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto">

            <!-- LEFT: Server tree -->
            <Grid Grid.Column="0" BackgroundColor="{DynamicResource ThemeBgPanel}" RowDefinitions="*,Auto"
                  WidthRequest="216">

                <ScrollView Grid.Row="0">
                    <VerticalStackLayout Spacing="0">

                        <!-- DM conversations list (visible in DM mode) -->
                        <VerticalStackLayout IsVisible="{Binding IsDmMode}" Spacing="0">
                            <Label Text="  MESSAGES" TextColor="{DynamicResource ThemeTextMuted}" FontSize="10"
                                   FontAttributes="Bold" Padding="8,8,8,4" />
                            <StackLayout BindableLayout.ItemsSource="{Binding DmConversations}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DmConversationItem">
                                        <Grid Padding="8,6,8,6"
                                              BackgroundColor="{Binding IsSelected, Converter={StaticResource ChannelSelectionConverter}}">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectDmConversationCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Avatar initials circle -->
                                                <Frame Grid.Column="0" CornerRadius="14" WidthRequest="28" HeightRequest="28"
                                                       BackgroundColor="{DynamicResource ThemeAccent}" Padding="0" Margin="0,0,8,0">
                                                    <Grid>
                                                        <Label Text="{Binding Initials}"
                                                               TextColor="White" FontSize="10" FontAttributes="Bold"
                                                               HorizontalOptions="Center" VerticalOptions="Center"
                                                               IsVisible="{Binding HasOtherAvatar, Converter={StaticResource InvertBoolConverter}}" />
                                                        <Image Source="{Binding OtherAvatarUrl}"
                                                               IsVisible="{Binding HasOtherAvatar}"
                                                               Aspect="AspectFill" />
                                                    </Grid>
                                                </Frame>
                                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                    <Label Text="{Binding OtherUsername}"
                                                           FontSize="12" FontAttributes="Bold"
                                                           TextColor="{Binding IsSelected, Converter={StaticResource ChannelTextConverter}}"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding LastMessagePreview}"
                                                           TextColor="{DynamicResource ThemeTextSecondary}" FontSize="10"
                                                           LineBreakMode="TailTruncation"
                                                           IsVisible="{Binding LastMessagePreview, Converter={StaticResource StringToBoolConverter}}" />
                                                </VerticalStackLayout>
                                                <!-- Unread badge -->
                                                <Border Grid.Column="2"
                                                        BackgroundColor="{DynamicResource ThemeDanger}"
                                                        StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                        Padding="5,1" MinimumWidthRequest="18"
                                                        IsVisible="{Binding HasUnread}"
                                                        VerticalOptions="Center">
                                                    <Label Text="{Binding UnreadCount}"
                                                           TextColor="White" FontSize="10" FontAttributes="Bold"
                                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                            <Label Text="Right-click any user to start a direct message."
                                   TextColor="{DynamicResource ThemeTextMuted}" FontSize="11"
                                   Padding="16,12" />
                        </VerticalStackLayout>

                        <!-- Server content (hidden in DM mode) -->
                        <VerticalStackLayout IsVisible="{Binding IsNotDmMode}" Spacing="0">

                        <!-- Connected users -->
                        <Label Text="  CONNECTED" TextColor="{DynamicResource ThemeTextMuted}" FontSize="10"
                               FontAttributes="Bold" Padding="8,8,8,4"
                               IsVisible="{Binding Members.Count, Converter={StaticResource NullToBoolConverter}}" />
                        <StackLayout BindableLayout.ItemsSource="{Binding Members}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:MemberViewItem">
                                    <Grid Padding="16,3,8,3" BackgroundColor="Transparent">
                                        <FlyoutBase.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="💬 Send Message"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StartDmWithUserCommand}"
                                                    CommandParameter="{Binding Id}" />
                                                <MenuFlyoutItem Text="🎤 Test My Mic (Loopback)"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleMicLoopbackCommand}" />
                                                <MenuFlyoutItem Text="↔ Move to Channel…"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PromptMoveMemberCommand}"
                                                    CommandParameter="{Binding .}"
                                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}" />
                                                <MenuFlyoutItem Text="👑 Make Admin"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ElevateToAdminCommand}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}" />
                                                <MenuFlyoutItem Text="🔇 Mute"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MuteUserByIdCommand}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}" />
                                                <MenuFlyoutItem Text="⛔ Temp Ban"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TempBanUserByIdCommand}"
                                                    CommandParameter="{Binding Id}"
                                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}" />
                                                <MenuFlyoutItem Text="🚫 Block / Unblock"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BlockUserByIdCommand}"
                                                    CommandParameter="{Binding Id}" />
                                            </MenuFlyout>
                                        </FlyoutBase.ContextFlyout>
                                        <HorizontalStackLayout Spacing="7">
                                            <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" VerticalOptions="Center"
                                                     BackgroundColor="{Binding Status, Converter={StaticResource StatusDotColorConverter}}" />
                                            <Label Text="{Binding RoleIcon}" FontSize="11" VerticalOptions="Center"
                                                   IsVisible="{Binding HasRoleIcon}" />
                                            <Label Text="{Binding Username}" TextColor="{DynamicResource ThemeTextPrimary}" FontSize="12" VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewProfileCommand}"
                                                        CommandParameter="{Binding Id}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{DynamicResource ThemeDivider}" Margin="0,4" />

                        <!-- Channels grouped by category -->
                        <StackLayout BindableLayout.ItemsSource="{Binding CategorizedChannels}" Spacing="0">
                            <FlyoutBase.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="+ Create Channel"
                                        Command="{Binding CreateChannelCommand}"
                                        IsEnabled="{Binding IsServerAdmin}" />
                                    <MenuFlyoutItem Text="🔤 Word Filter"
                                        Command="{Binding ManageWordFilterCommand}"
                                        IsEnabled="{Binding IsServerAdmin}" />
                                    <MenuFlyoutItem Text="📷 Change Icon"
                                        Command="{Binding ChangeServerIconCommand}"
                                        IsEnabled="{Binding IsServerAdmin}" />
                                    <MenuFlyoutItem Text="🗑 Remove Icon"
                                        Command="{Binding RemoveServerIconCommand}"
                                        IsEnabled="{Binding IsServerAdmin}" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="🔔 All Notifications"
                                        Command="{Binding SetServerNotifLevelCommand}"
                                        CommandParameter="All" />
                                    <MenuFlyoutItem Text="🔕 Mentions Only"
                                        Command="{Binding SetServerNotifLevelCommand}"
                                        CommandParameter="OnlyMentions" />
                                    <MenuFlyoutItem Text="🚫 Mute Server"
                                        Command="{Binding SetServerNotifLevelCommand}"
                                        CommandParameter="Muted" />
                                </MenuFlyout>
                            </FlyoutBase.ContextFlyout>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryViewItem">
                                    <VerticalStackLayout Spacing="0">
                                        <!-- Category header -->
                                        <Grid Padding="8,6,8,2" BackgroundColor="Transparent">
                                            <FlyoutBase.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="✏ Rename"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RenameCategoryCommand}"
                                                        CommandParameter="{Binding .}"
                                                        IsEnabled="{Binding IsRealCategory}" />
                                                    <MenuFlyoutItem Text="🗑 Delete Category"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCategoryCommand}"
                                                        CommandParameter="{Binding .}"
                                                        IsEnabled="{Binding IsRealCategory}" />
                                                </MenuFlyout>
                                            </FlyoutBase.ContextFlyout>
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleCategoryCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Label Grid.Column="0" Text="{Binding ToggleIcon}" TextColor="{DynamicResource ThemeTextMuted}" FontSize="9" VerticalOptions="Center" Margin="0,0,4,0" />
                                                <Label Grid.Column="1" Text="{Binding Name}" TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" FontAttributes="Bold" VerticalOptions="Center" />
                                            </Grid>
                                        </Grid>
                                        <!-- Channels in this category -->
                                        <StackLayout BindableLayout.ItemsSource="{Binding Channels}"
                                                     IsVisible="{Binding IsCollapsed, Converter={StaticResource InvertBoolConverter}}"
                                                     Spacing="0">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ChannelViewItem">
                                                    <VerticalStackLayout Spacing="0">
                                                        <Grid Padding="8,5,8,5"
                                                              BackgroundColor="{Binding IsSelected, Converter={StaticResource ChannelSelectionConverter}}">
                                                            <VisualStateManager.VisualStateGroups>
                                                                <VisualStateGroup x:Name="CommonStates">
                                                                    <VisualState x:Name="Normal" />
                                                                    <VisualState x:Name="PointerOver">
                                                                        <VisualState.Setters>
                                                                            <Setter Property="BackgroundColor" Value="{DynamicResource ThemeBgActive}" />
                                                                        </VisualState.Setters>
                                                                    </VisualState>
                                                                </VisualStateGroup>
                                                            </VisualStateManager.VisualStateGroups>
                                                            <FlyoutBase.ContextFlyout>
                                                                <MenuFlyout>
                                                                    <MenuFlyoutItem Text="📁 Move to Category"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetChannelCategoryCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                                    <MenuFlyoutItem Text="⏱ Set Slowmode"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetSlowmodeCommand}"
                                                                        CommandParameter="{Binding .}" />
                                                                    <MenuFlyoutSeparator />
                                                                    <MenuFlyoutItem Text="🔔 All Notifications"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetChannelNotifLevelCommand}"
                                                                        CommandParameter="All" />
                                                                    <MenuFlyoutItem Text="🔕 Mentions Only"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetChannelNotifLevelCommand}"
                                                                        CommandParameter="OnlyMentions" />
                                                                    <MenuFlyoutItem Text="🚫 Mute Channel"
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetChannelNotifLevelCommand}"
                                                                        CommandParameter="Muted" />
                                                                </MenuFlyout>
                                                            </FlyoutBase.ContextFlyout>
                                                            <Grid.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectChannelCommand}"
                                                                    CommandParameter="{Binding .}" />
                                                                <DropGestureRecognizer
                                                                    AllowDrop="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}"
                                                                    DragOver="OnChannelDragOver"
                                                                    Drop="OnChannelDrop" />
                                                            </Grid.GestureRecognizers>
                                                            <BoxView WidthRequest="3" HorizontalOptions="Start" VerticalOptions="Fill"
                                                                     Color="{DynamicResource ThemeAccent}" Margin="-8,-5,0,-5"
                                                                     IsVisible="{Binding IsSelected}" />
                                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                                <Label Grid.Column="0" Text="📢" FontSize="11" VerticalOptions="Center" />
                                                                <Label Grid.Column="1" Text="{Binding Channel.Name}" FontSize="12" VerticalOptions="Center"
                                                                       TextColor="{Binding IsSelected, Converter={StaticResource ChannelTextConverter}}"
                                                                       FontAttributes="{Binding IsSelected, Converter={StaticResource SelectedFontConverter}}"
                                                                       Margin="7,0,0,0" />
                                                                <HorizontalStackLayout Grid.Column="2" Spacing="3" VerticalOptions="Center">
                                                                    <Label Text="{Binding NotifIcon}" FontSize="9" VerticalOptions="Center"
                                                                           IsVisible="{Binding NotifLevelOverride, Converter={StaticResource NullToBoolConverter}}" />
                                                                    <Border BackgroundColor="{DynamicResource ThemeWarning}"
                                                                            StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                                            Padding="5,1" MinimumWidthRequest="18"
                                                                            IsVisible="{Binding HasMention}">
                                                                        <Label Text="{Binding MentionBadge}"
                                                                               TextColor="White" FontSize="10" FontAttributes="Bold"
                                                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                                                    </Border>
                                                                    <Border BackgroundColor="{Binding HasUnread, Converter={StaticResource UnreadBadgeBgConverter}}"
                                                                            StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                                                            Padding="5,1" MinimumWidthRequest="18"
                                                                            IsVisible="{Binding HasUnread}">
                                                                        <Label Text="{Binding UnreadBadge}"
                                                                               TextColor="White" FontSize="10" FontAttributes="Bold"
                                                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                                                    </Border>
                                                                </HorizontalStackLayout>
                                                            </Grid>
                                                        </Grid>
                                                        <!-- Users in this channel -->
                                                        <StackLayout BindableLayout.ItemsSource="{Binding Occupants}" Spacing="0">
                                                            <BindableLayout.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:OccupantViewModel">
                                                                    <Grid Padding="28,3,8,3" BackgroundColor="Transparent">
                                                                        <Grid.GestureRecognizers>
                                                                            <DragGestureRecognizer
                                                                                CanDrag="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}"
                                                                                DragStarting="OnOccupantDragStarting" />
                                                                        </Grid.GestureRecognizers>
                                                                        <FlyoutBase.ContextFlyout>
                                                                            <MenuFlyout>
                                                                                <MenuFlyoutItem Text="↔ Move to Channel…"
                                                                                    IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}"
                                                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PromptMoveUserCommand}"
                                                                                    CommandParameter="{Binding .}" />
                                                                            </MenuFlyout>
                                                                        </FlyoutBase.ContextFlyout>
                                                                        <HorizontalStackLayout Spacing="6">
                                                                            <Label Text="🎧" FontSize="10" TextColor="{DynamicResource ThemeAccentLight}" VerticalOptions="Center"
                                                                                   IsVisible="{Binding IsSpeaking, Converter={StaticResource InvertBoolConverter}}" />
                                                                            <Label Text="🔊" FontSize="10" TextColor="#44ee44" VerticalOptions="Center"
                                                                                   IsVisible="{Binding IsSpeaking}" />
                                                                            <Label Text="{Binding Username}" FontSize="11" VerticalOptions="Center"
                                                                                   TextColor="{DynamicResource ThemeTextSecondary}" />
                                                                        </HorizontalStackLayout>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </BindableLayout.ItemTemplate>
                                                        </StackLayout>
                                                    </VerticalStackLayout>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </StackLayout>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>
                        <Button Text="+ New Channel"
                                Command="{Binding CreateChannelCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextMuted}"
                                FontSize="11" HeightRequest="30" Padding="8,0"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsServerAdmin}"
                                ToolTipProperties.Text="Create a new channel" />
                        <Button Text="+ New Category"
                                Command="{Binding CreateCategoryPromptCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextMuted}"
                                FontSize="11" HeightRequest="30" Padding="8,0"
                                HorizontalOptions="Start"
                                IsVisible="{Binding IsServerAdmin}"
                                ToolTipProperties.Text="Create a new channel category" />

                        <!-- Invite actions -->
                        <BoxView HeightRequest="1" BackgroundColor="{DynamicResource ThemeDivider}" Margin="0,6,0,2" />
                        <Button Text="+ Join with Invite Code"
                                Command="{Binding JoinByInviteCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextMuted}"
                                FontSize="11" HeightRequest="30" Padding="8,0"
                                HorizontalOptions="Start" />
                        <Button Text="↺ Reset Invite Link"
                                Command="{Binding ResetInviteLinkCommand}"
                                IsVisible="{Binding IsServerAdmin}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextMuted}"
                                FontSize="10" HeightRequest="26" Padding="8,0"
                                HorizontalOptions="Start"
                                ToolTipProperties.Text="Invalidate current link and generate a new one" />

                        </VerticalStackLayout><!-- end server content -->

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Profile bar -->
                <Grid Grid.Row="1" BackgroundColor="{DynamicResource ThemeBgHeader}" Padding="8,7"
                      ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                    <Frame Grid.Column="0" CornerRadius="14" WidthRequest="28" HeightRequest="28"
                           BackgroundColor="{DynamicResource ThemeAccent}" Padding="0" Margin="0,0,8,0">
                        <Grid>
                            <Label Text="{Binding CurrentUsername, Converter={StaticResource InitialsConverter}}"
                                   TextColor="White" FontSize="9" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   IsVisible="{Binding HasCurrentUserAvatar, Converter={StaticResource InvertBoolConverter}}" />
                            <Image Source="{Binding CurrentUserAvatarUrl}"
                                   IsVisible="{Binding HasCurrentUserAvatar}"
                                   Aspect="AspectFill" />
                        </Grid>
                    </Frame>
                    <Label Grid.Column="1" Text="{Binding CurrentUsername}"
                           TextColor="{DynamicResource ThemeTextPrimary}" FontSize="12" FontAttributes="Bold"
                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                    <Button Grid.Column="2" Text="💬"
                            Command="{Binding ToggleDmModeCommand}"
                            BackgroundColor="Transparent" TextColor="{DynamicResource ThemeAccentLight}"
                            FontSize="13" HeightRequest="28" WidthRequest="32" Padding="0"
                            ToolTipProperties.Text="Direct Messages" />
                    <Button Grid.Column="3" Text="🔗"
                            Command="{Binding CopyInviteLinkCommand}"
                            IsVisible="{Binding IsServerAdmin}"
                            BackgroundColor="Transparent" TextColor="{DynamicResource ThemeAccentLight}"
                            FontSize="13" HeightRequest="28" WidthRequest="32" Padding="0"
                            ToolTipProperties.Text="Copy invite link" />
                    <Button Grid.Column="4" Text="📷"
                            Command="{Binding UploadAvatarCommand}"
                            BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextMuted}"
                            FontSize="13" HeightRequest="28" WidthRequest="32" Padding="0"
                            ToolTipProperties.Text="Change profile picture" />
                </Grid>
            </Grid>

            <!-- RIGHT: Chat panel -->
            <Grid Grid.Column="1" BackgroundColor="{DynamicResource ThemeBgPrimary}" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">

                <!-- Channel header / DM header -->
                <Grid Grid.Row="0" BackgroundColor="{DynamicResource ThemeBgHeader}" RowDefinitions="Auto,Auto">
                    <!-- Channel header (hidden in DM mode) -->
                    <Grid Grid.Row="0" Padding="14,8" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                          IsVisible="{Binding IsNotDmMode}">
                        <Label Grid.Column="0" Text="#" TextColor="{DynamicResource ThemeTextMuted}" FontSize="16" VerticalOptions="Center" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center" Margin="6,0,0,0">
                            <Label Text="{Binding SelectedChannel.Name, FallbackValue='Select a channel'}"
                                   TextColor="{DynamicResource ThemeTextPrimary}" FontAttributes="Bold" FontSize="13"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding CurrentChannelSlowmodeLabel}"
                                   TextColor="{DynamicResource ThemeWarning}" FontSize="10"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding CurrentChannelHasSlowmode}" />
                        </HorizontalStackLayout>
                        <Button Grid.Column="2" Text="🐷 Ask PorkChop"
                                Command="{Binding AskPorkChopCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeAccentLight}"
                                FontSize="12" HeightRequest="34" Padding="8,0"
                                ToolTipProperties.Text="Ask PorkChop a question"
                                IsVisible="{Binding SelectedChannel, Converter={StaticResource NullToBoolConverter}}" />
                        <Button Grid.Column="3" Text="🗞"
                                Command="{Binding CatchMeUpCommand}"
                                IsEnabled="{Binding IsCatchingUp, Converter={StaticResource InvertBoolConverter}}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeAccentLight}"
                                FontSize="14" HeightRequest="34" WidthRequest="36" Padding="0"
                                ToolTipProperties.Text="Catch me up — what you missed since last online"
                                IsVisible="{Binding SelectedChannel, Converter={StaticResource NullToBoolConverter}}" />
                        <Button Grid.Column="4" Text="📌"
                                Command="{Binding TogglePinsCommand}"
                                BackgroundColor="{Binding IsPinsOpen, Converter={StaticResource TabBgConverter}}"
                                TextColor="{DynamicResource ThemeTextSecondary}"
                                FontSize="14" HeightRequest="34" WidthRequest="36" Padding="0"
                                IsVisible="{Binding SelectedChannel, Converter={StaticResource NullToBoolConverter}}" />
                        <Button Grid.Column="5" Text="🔍"
                                Command="{Binding ToggleSearchCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextSecondary}"
                                FontSize="14" HeightRequest="34" WidthRequest="36" Padding="0"
                                IsVisible="{Binding SelectedChannel, Converter={StaticResource NullToBoolConverter}}" />
                    </Grid>
                    <!-- DM header (visible in DM mode) -->
                    <Grid Grid.Row="0" Padding="8,8" ColumnDefinitions="Auto,*,Auto"
                          IsVisible="{Binding IsDmMode}">
                        <Button Grid.Column="0" Text="←"
                                Command="{Binding ToggleDmModeCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeAccentLight}"
                                FontSize="14" HeightRequest="30" WidthRequest="34" Padding="0" />
                        <Label Grid.Column="1" Text="{Binding DmHeaderTitle, StringFormat='💬  {0}'}"
                               TextColor="{DynamicResource ThemeTextPrimary}" FontAttributes="Bold" FontSize="13"
                               VerticalOptions="Center" Margin="4,0,0,0" />
                        <Button Grid.Column="2" Text="📌"
                                Command="{Binding TogglePinsCommand}"
                                BackgroundColor="{Binding IsPinsOpen, Converter={StaticResource TabBgConverter}}"
                                TextColor="{DynamicResource ThemeTextSecondary}"
                                FontSize="14" HeightRequest="30" WidthRequest="36" Padding="0"
                                IsVisible="{Binding SelectedDmConversation, Converter={StaticResource NullToBoolConverter}}" />
                    </Grid>
                    <Grid Grid.Row="1" IsVisible="{Binding IsSearchOpen}"
                          Padding="10,4,10,6" ColumnDefinitions="*,Auto,Auto" BackgroundColor="{DynamicResource ThemeBgPanel}">
                        <Entry Grid.Column="0"
                               Text="{Binding SearchQuery}"
                               Placeholder="Search in channel…"
                               PlaceholderColor="#4a443d" TextColor="{DynamicResource ThemeTextPrimary}"
                               BackgroundColor="{DynamicResource ThemeBgPanel}" FontSize="12"
                               ReturnCommand="{Binding SearchCommand}" />
                        <Button Grid.Column="1" Text="Search"
                                Command="{Binding SearchCommand}"
                                BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White"
                                FontSize="11" CornerRadius="3" Padding="10,0"
                                HeightRequest="32" Margin="6,0,0,0" />
                        <Button Grid.Column="2" Text="✕"
                                Command="{Binding ClearSearchCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextSecondary}"
                                FontSize="13" HeightRequest="32" WidthRequest="32" Padding="0"
                                Margin="4,0,0,0" />
                    </Grid>
                </Grid>

                <!-- Tab bar -->
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" HeightRequest="34" BackgroundColor="{DynamicResource ThemeBgElevated}"
                      IsVisible="{Binding ShowChannelUiElements}">
                    <Button Grid.Column="0" Text="💬 Chat"
                            Command="{Binding SelectTabCommand}" CommandParameter="Text"
                            BackgroundColor="{Binding IsTextTab, Converter={StaticResource TabBgConverter}}"
                            TextColor="White" FontSize="11" CornerRadius="0" BorderWidth="0"
                            Padding="0" Margin="0" />
                    <Button Grid.Column="1" Text="🎙 Voice"
                            Command="{Binding SelectTabCommand}" CommandParameter="Voice"
                            BackgroundColor="{Binding IsVoiceTab, Converter={StaticResource TabBgConverter}}"
                            TextColor="White" FontSize="11" CornerRadius="0" BorderWidth="0"
                            Padding="0" Margin="0" />
                    <Button Grid.Column="2" Text="📺 Stream"
                            Command="{Binding SelectTabCommand}" CommandParameter="Stream"
                            BackgroundColor="{Binding IsStreamTab, Converter={StaticResource TabBgConverter}}"
                            TextColor="White" FontSize="11" CornerRadius="0" BorderWidth="0"
                            Padding="0" Margin="0"
                            Opacity="{Binding StreamTabOpacity}" />
                </Grid>

                <!-- Voice participants strip + video tiles -->
                <VerticalStackLayout Grid.Row="2"
                                     IsVisible="{Binding ShowChannelUiElements}">
                    <!-- Voice participants row -->
                    <Grid BackgroundColor="{DynamicResource ThemeBgElevated}" Padding="12,5">
                        <HorizontalStackLayout Spacing="14">
                            <HorizontalStackLayout Spacing="5">
                                <Ellipse WidthRequest="8" HeightRequest="8" Fill="#36b864" VerticalOptions="Center" />
                                <Label Text="Voice Active" TextColor="{DynamicResource ThemeSuccess}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <StackLayout BindableLayout.ItemsSource="{Binding VoiceParticipants}"
                                         Orientation="Horizontal" Spacing="10">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:VoiceParticipantViewModel">
                                        <HorizontalStackLayout Spacing="5" Padding="2,0">
                                            <FlyoutBase.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="👑 Make Admin"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ElevateToAdminCommand}"
                                                        CommandParameter="{Binding UserId}"
                                                        IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}" />
                                                    <MenuFlyoutItem Text="🔇 Mute"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MuteUserByIdCommand}"
                                                        CommandParameter="{Binding UserId}"
                                                        IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}" />
                                                    <MenuFlyoutItem Text="⛔ Temp Ban"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TempBanUserByIdCommand}"
                                                        CommandParameter="{Binding UserId}"
                                                        IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsServerAdmin}" />
                                                    <MenuFlyoutItem Text="🚫 Block / Unblock"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BlockUserByIdCommand}"
                                                        CommandParameter="{Binding UserId}" />
                                                </MenuFlyout>
                                            </FlyoutBase.ContextFlyout>
                                            <Ellipse WidthRequest="7" HeightRequest="7"
                                                     Fill="{Binding DotColor}"
                                                     VerticalOptions="Center" />
                                            <Label Text="{Binding Username}"
                                                   TextColor="{Binding NameColor}"
                                                   FontAttributes="{Binding NameFont}"
                                                   FontSize="11" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </HorizontalStackLayout>
                    </Grid>
                    <!-- Video tiles (visible when any camera is on) -->
                    <CollectionView ItemsSource="{Binding VideoTiles}"
                                    IsVisible="{Binding HasVideoTiles}"
                                    HeightRequest="150"
                                    BackgroundColor="{DynamicResource ThemeBgHeader}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="4" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:VideoTileViewModel">
                                <Grid WidthRequest="200" HeightRequest="150" BackgroundColor="{DynamicResource ThemeBgPrimary}">
                                    <Image Source="{Binding Frame}" Aspect="AspectFill" />
                                    <Border VerticalOptions="End" HorizontalOptions="Fill"
                                            BackgroundColor="#99000000" StrokeThickness="0" Padding="6,3">
                                        <Label Text="{Binding Username}"
                                               TextColor="White" FontSize="11" FontAttributes="Bold"
                                               HorizontalOptions="Start" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Stream viewer -->
                <Grid Grid.Row="3" BackgroundColor="{DynamicResource ThemeBgHeader}"
                      IsVisible="{Binding StreamViewerVisible}"
                      RowDefinitions="Auto,480">
                    <Grid Grid.Row="0" BackgroundColor="{DynamicResource ThemeBgElevated}" ColumnDefinitions="*,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="{Binding StreamHeaderText}"
                               TextColor="{DynamicResource ThemeAccentLight}" FontSize="11" FontAttributes="Bold"
                               VerticalOptions="Center" Padding="8,5" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center" Margin="0,0,8,0">
                            <Ellipse WidthRequest="8" HeightRequest="8"
                                     Fill="{Binding StreamLatencyColor}" VerticalOptions="Center" />
                            <Label Text="{Binding StreamLatencyText}" TextColor="{DynamicResource ThemeTextSecondary}" FontSize="10" VerticalOptions="Center" />
                            <Label Text="·" TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" VerticalOptions="Center" />
                            <Label Text="{Binding StreamQualityLabel}" TextColor="{DynamicResource ThemeTextSecondary}" FontSize="10" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Button Grid.Column="2" Text="💬"
                                Command="{Binding ToggleStreamChatOverlayCommand}"
                                BackgroundColor="{Binding IsStreamChatOverlayVisible, Converter={StaticResource ChannelSelectionConverter}}"
                                TextColor="{DynamicResource ThemeAccentLight}" FontSize="13"
                                HeightRequest="30" WidthRequest="36" Padding="0" Margin="0,0,2,0"
                                ToolTipProperties.Text="Toggle chat overlay" />
                        <Button Grid.Column="3" Text="⛶"
                                Command="{Binding ToggleFullScreenCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeAccentLight}" FontSize="15"
                                HeightRequest="30" WidthRequest="36" Padding="0" Margin="0,0,4,0"
                                ToolTipProperties.Text="Pop out to separate window" />
                    </Grid>
                    <Grid Grid.Row="1" IsVisible="{Binding IsStreaming}" BackgroundColor="{DynamicResource ThemeBgElevated}">
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <Label Text="🟢  You are sharing your screen"
                                   TextColor="{DynamicResource ThemeSuccess}" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="{Binding StreamQualityLabel, StringFormat='Quality: {0}'}"
                                   TextColor="{DynamicResource ThemeSuccess}" FontSize="11" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <!-- Give control button (sharer offers to most-recently-joined viewer; viewer id via OfferControlCommand with 0 = pending) -->
                        <!-- Note: OfferControl requires a viewer id. Without a viewer panel, this button is wired but hidden until CanOfferControl. -->
                        <!-- Being-controlled banner (sharer side) -->
                        <Grid VerticalOptions="End" HorizontalOptions="Fill"
                              BackgroundColor="#CC8B0000"
                              IsVisible="{Binding IsBeingControlled}"
                              Padding="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Text="{Binding ControllerName, StringFormat='🖱 {0} is controlling your screen'}"
                                   TextColor="White" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="Stop control"
                                    Command="{Binding StopControlCommand}"
                                    BackgroundColor="{DynamicResource ThemeDanger}" TextColor="White" FontSize="10"
                                    HeightRequest="26" CornerRadius="3" Padding="8,0" />
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="1" IsVisible="{Binding IsStreaming, Converter={StaticResource InvertBoolConverter}}">
                        <Image Source="{Binding StreamFrame}" Aspect="AspectFit"
                               BackgroundColor="{DynamicResource ThemeBgHeader}" IsVisible="{Binding HasStreamFrame}" />
                        <Label Text="⏳  Connecting to stream…"
                               TextColor="{DynamicResource ThemeTextMuted}" FontSize="12" FontAttributes="Italic"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               IsVisible="{Binding IsWaitingForStream}" />
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6"
                                             IsVisible="{Binding HasActiveStream, Converter={StaticResource InvertBoolConverter}}">
                            <Label Text="📺" FontSize="36" HorizontalOptions="Center" />
                            <Label Text="No active stream" TextColor="{DynamicResource ThemeTextMuted}" FontSize="13"
                                   FontAttributes="Italic" HorizontalOptions="Center" />
                            <Label Text="A notification will appear in chat when someone shares."
                                   TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <!-- Stream chat overlay -->
                        <Border IsVisible="{Binding IsStreamChatOverlayVisible}"
                                VerticalOptions="End" HorizontalOptions="Start"
                                Margin="10,0,0,10"
                                BackgroundColor="#CC000000"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 8"
                                WidthRequest="280">
                            <CollectionView ItemsSource="{Binding StreamOverlayMessages}"
                                            MaximumHeightRequest="220">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MessageViewItem">
                                        <VerticalStackLayout Padding="8,4" Spacing="1">
                                            <Label Text="{Binding Message.AuthorUsername}"
                                                   TextColor="{DynamicResource ThemeAccentLight}" FontSize="11" FontAttributes="Bold" />
                                            <Label Text="{Binding Message.Content}"
                                                   TextColor="{DynamicResource ThemeTextPrimary}" FontSize="11"
                                                   LineBreakMode="TailTruncation" MaxLines="2" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                        <!-- Request control button (viewer side) -->
                        <Button Text="🖱 Request Control"
                                Command="{Binding RequestControlCommand}"
                                BackgroundColor="#CCd42d00"
                                TextColor="White" FontSize="10"
                                HorizontalOptions="End" VerticalOptions="End"
                                Margin="0,0,8,8"
                                HeightRequest="26" CornerRadius="3" Padding="8,0"
                                IsVisible="{Binding CanRequestControl}" />
                        <!-- Controlling banner (controller side) -->
                        <Grid VerticalOptions="End" HorizontalOptions="Fill"
                              BackgroundColor="#CCd42d00"
                              IsVisible="{Binding IsControlling}"
                              Padding="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0"
                                   Text="{Binding ControlledName, StringFormat='🖱 You are controlling {0}\'s screen'}"
                                   TextColor="White" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                            <Button Grid.Column="1"
                                    Text="Release"
                                    Command="{Binding ReleaseControlCommand}"
                                    BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White" FontSize="10"
                                    HeightRequest="26" CornerRadius="3" Padding="8,0" />
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Compact bar when stream is popped out -->
                <Grid Grid.Row="3" BackgroundColor="{DynamicResource ThemeBgElevated}" Padding="12,6" IsVisible="{Binding IsFullScreen}">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="{Binding ActiveStreamerName, StringFormat='📺  {0} — stream in separate window'}"
                               TextColor="{DynamicResource ThemeAccentLight}" FontSize="11" VerticalOptions="Center" />
                        <Button Text="↩ Return to In-App"
                                Command="{Binding ToggleFullScreenCommand}"
                                BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White" FontSize="10"
                                HeightRequest="26" CornerRadius="3" Padding="10,0" />
                    </HorizontalStackLayout>
                </Grid>

                <!-- Messages + new-message pill overlay -->
                <Grid Grid.Row="4" IsVisible="{Binding ShowMessages}">
                <CollectionView x:Name="MessagesView" ItemsSource="{Binding Messages}"
                                BackgroundColor="{DynamicResource ThemeBgPrimary}"
                                Scrolled="OnMessagesScrolled">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageViewItem">
                            <VerticalStackLayout>
                                <!-- Day header (tap to collapse/expand that day) -->
                                <Grid IsVisible="{Binding IsDayHeader}" Padding="14,8,14,4"
                                      ColumnDefinitions="Auto,Auto,*,Auto" BackgroundColor="{DynamicResource ThemeBgPrimary}">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleDayCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" Text="{Binding DayChevron}" IsVisible="{Binding ShowDayChevron}" TextColor="{DynamicResource ThemeTextMuted}" FontSize="9" VerticalOptions="Center" Margin="0,0,6,0" />
                                    <Label Grid.Column="1" Text="{Binding DayLabel}" TextColor="{DynamicResource ThemeTextSecondary}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                                    <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="{DynamicResource ThemeDivider}" VerticalOptions="Center" Margin="10,0" />
                                    <Label Grid.Column="3" Text="{Binding DayCountLabel}" TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" VerticalOptions="Center"
                                           IsVisible="{Binding IsDayCollapsed}" />
                                </Grid>
                                <!-- Day summary: PorkChop's recap of a past day -->
                                <Grid IsVisible="{Binding IsDaySummary}" Padding="20,2,20,8" RowDefinitions="Auto,Auto">
                                    <Border Grid.Row="0" BackgroundColor="{DynamicResource ThemeBgElevated}" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8" Padding="12,10">
                                        <VerticalStackLayout Spacing="6">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="🐷" FontSize="13" VerticalOptions="Center" />
                                                <Label Text="PorkChop's recap" TextColor="{DynamicResource ThemeAccentLight}" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding SummaryText}" TextColor="{DynamicResource ThemeTextPrimary}" FontSize="12" LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Label Grid.Row="1" Text="{Binding ShowMessagesLabel}" TextColor="{DynamicResource ThemeAccentLight}" FontSize="10" Margin="4,5,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ShowDayMessagesCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                                <!-- New messages divider -->
                                <Grid IsVisible="{Binding IsNewMessageDivider}" Padding="14,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="{DynamicResource ThemeDanger}" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="  NEW MESSAGES  "
                                           TextColor="{DynamicResource ThemeDanger}" FontSize="10" FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                    <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="{DynamicResource ThemeDanger}" VerticalOptions="Center"/>
                                </Grid>
                                <!-- System notification -->
                                <Label IsVisible="{Binding IsSystemMessage}"
                                       Text="{Binding Message.Content}"
                                       TextColor="{DynamicResource ThemeSuccess}" FontSize="11" FontAttributes="Italic"
                                       HorizontalOptions="Center" Padding="0,5" />
                                <!-- Regular message -->
                                <Grid Padding="14,6" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      IsVisible="{Binding IsRegularMessage}"
                                      BackgroundColor="{Binding IsMention, Converter={StaticResource MentionBgConverter}}">
                                    <FlyoutBase.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="↩ Reply"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ReplyCommand}"
                                                CommandParameter="{Binding .}" />
                                            <MenuFlyoutItem Text="🧵 Open Thread"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenThreadCommand}"
                                                CommandParameter="{Binding .}" />
                                            <MenuFlyoutItem Text="✏ Edit Message"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditMessageCommand}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding IsOwnMessage}" />
                                            <MenuFlyoutItem Text="🗑 Delete Message"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteMessageCommand}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding CanDelete}" />
                                            <MenuFlyoutItem Text="📌 Pin / Unpin"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TogglePinMessageCommand}"
                                                CommandParameter="{Binding .}" />
                                            <MenuFlyoutItem Text="🚫 Block User"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleBlockUserCommand}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding IsOwnMessage, Converter={StaticResource InvertBoolConverter}}" />
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutSubItem Text="😊 React">
                                                <MenuFlyoutItem Text="👍" Command="{Binding ToggleReactionCommand}" CommandParameter="👍" />
                                                <MenuFlyoutItem Text="❤️" Command="{Binding ToggleReactionCommand}" CommandParameter="❤️" />
                                                <MenuFlyoutItem Text="😂" Command="{Binding ToggleReactionCommand}" CommandParameter="😂" />
                                                <MenuFlyoutItem Text="🎉" Command="{Binding ToggleReactionCommand}" CommandParameter="🎉" />
                                                <MenuFlyoutItem Text="😮" Command="{Binding ToggleReactionCommand}" CommandParameter="😮" />
                                                <MenuFlyoutItem Text="😢" Command="{Binding ToggleReactionCommand}" CommandParameter="😢" />
                                            </MenuFlyoutSubItem>
                                        </MenuFlyout>
                                    </FlyoutBase.ContextFlyout>
                                    <!-- Reply quote (shown above author when replying to a message) -->
                                    <Border Grid.Row="0" Grid.Column="1"
                                            IsVisible="{Binding HasReply}"
                                            BackgroundColor="{DynamicResource ThemeBgPanel}" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            Margin="0,2,0,4" Padding="8,4">
                                        <HorizontalStackLayout Spacing="8">
                                            <BoxView WidthRequest="3" BackgroundColor="{DynamicResource ThemeAccent}"
                                                     CornerRadius="1" VerticalOptions="Fill" />
                                            <VerticalStackLayout Spacing="0">
                                                <Label Text="{Binding ReplyAuthor}"
                                                       TextColor="{DynamicResource ThemeAccentLight}" FontSize="10" FontAttributes="Bold" />
                                                <Label Text="{Binding ReplyBodyPreview}"
                                                       TextColor="{DynamicResource ThemeTextSecondary}" FontSize="10"
                                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <!-- Avatar -->
                                    <Frame Grid.Row="0" Grid.RowSpan="6" Grid.Column="0"
                                           CornerRadius="18" WidthRequest="36" HeightRequest="36"
                                           BackgroundColor="{DynamicResource ThemeAccent}" Padding="0" Margin="0,0,10,0"
                                           VerticalOptions="Start">
                                        <Grid>
                                            <Label Text="{Binding Message.AuthorUsername, Converter={StaticResource InitialsConverter}}"
                                                   TextColor="White" FontSize="12" FontAttributes="Bold"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   IsVisible="{Binding HasAvatarImage, Converter={StaticResource InvertBoolConverter}}" />
                                            <Image Source="{Binding Message.AuthorAvatarUrl}"
                                                   IsVisible="{Binding HasAvatarImage}"
                                                   Aspect="AspectFill" />
                                        </Grid>
                                    </Frame>
                                    <!-- Author + time + edited badge -->
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                        <Label Text="{Binding AuthorDisplayName}" TextColor="{DynamicResource ThemeAccentLight}"
                                               FontAttributes="Bold" FontSize="13">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.ViewProfileCommand, Source={x:Reference RootPage}}"
                                                    CommandParameter="{Binding Message.AuthorId}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <Label Text="{Binding AuthorRoleIcon}" FontSize="11" VerticalOptions="Center"
                                               IsVisible="{Binding HasAuthorRoleIcon}" />
                                        <Label FontFamily="DMMono" Text="{Binding Message.CreatedAt, Converter={StaticResource UtcToLocalTimeConverter}}"
                                               TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" VerticalOptions="End" Margin="0,0,0,1" />
                                        <Label Text="(edited)" TextColor="{DynamicResource ThemeTextMuted}" FontSize="10"
                                               VerticalOptions="End" Margin="0,0,0,1"
                                               IsVisible="{Binding IsEdited}" />
                                        <Label Text="@mention" TextColor="{DynamicResource ThemeWarning}" FontSize="10" FontAttributes="Bold"
                                               VerticalOptions="End" Margin="0,0,0,1"
                                               IsVisible="{Binding IsMention}" />
                                        <Label Text="🤖 AI" TextColor="#a855f7" FontSize="10" FontAttributes="Bold"
                                               VerticalOptions="End" Margin="0,0,0,1"
                                               IsVisible="{Binding IsBot}" />
                                        <Label Text="📌" TextColor="{DynamicResource ThemeWarning}" FontSize="10"
                                               VerticalOptions="End" Margin="0,0,0,1"
                                               IsVisible="{Binding IsPinned}" />
                                    </HorizontalStackLayout>
                                    <!-- Deleted state -->
                                    <Label Grid.Row="2" Grid.Column="1"
                                           Text="✗  This message was deleted."
                                           TextColor="{DynamicResource ThemeTextMuted}" FontSize="12" FontAttributes="Italic"
                                           IsVisible="{Binding IsDeleted}" />
                                    <!-- Normal content (hidden when deleted) -->
                                    <controls:MarkdownView Grid.Row="2" Grid.Column="1"
                                           Text="{Binding Message.Content}"
                                           IsVisible="{Binding IsDeleted, Converter={StaticResource InvertBoolConverter}}" />
                                    <!-- Static attachment (non-GIF) -->
                                    <Image Grid.Row="3" Grid.Column="1"
                                           Source="{Binding Message.AttachmentUrl}"
                                           IsVisible="{Binding HasStaticAttachment}"
                                           Aspect="AspectFit"
                                           MaximumHeightRequest="300"
                                           HorizontalOptions="Start"
                                           WidthRequest="400"
                                           Margin="0,4,0,0" />
                                    <!-- GIF (playing) -->
                                    <Image Grid.Row="3" Grid.Column="1"
                                           Source="{Binding AttachmentDisplayUrl}"
                                           IsVisible="{Binding IsGifPlaying}"
                                           Aspect="AspectFit"
                                           MaximumHeightRequest="300"
                                           HorizontalOptions="Start"
                                           WidthRequest="400"
                                           Margin="0,4,0,0" />
                                    <!-- GIF paused -->
                                    <Border Grid.Row="3" Grid.Column="1"
                                            IsVisible="{Binding GifPaused}"
                                            BackgroundColor="{DynamicResource ThemeBgHeader}"
                                            StrokeThickness="1" Stroke="#292525"
                                            StrokeShape="RoundRectangle 6"
                                            WidthRequest="160" HeightRequest="38"
                                            HorizontalOptions="Start"
                                            Margin="0,4,0,0">
                                        <Button Text="▶ Replay GIF"
                                                Command="{Binding ReplayGifCommand}"
                                                BackgroundColor="Transparent"
                                                TextColor="{DynamicResource ThemeAccentLight}" FontSize="11"
                                                Padding="0" HeightRequest="38" />
                                    </Border>
                                    <!-- File attachment card (non-image files) -->
                                    <Border Grid.Row="3" Grid.Column="1"
                                            IsVisible="{Binding IsFileAttachment}"
                                            BackgroundColor="{DynamicResource ThemeBgPanel}"
                                            StrokeThickness="1" Stroke="#292525"
                                            StrokeShape="RoundRectangle 6"
                                            HorizontalOptions="Start"
                                            Margin="0,4,0,0" Padding="10,8">
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding AttachmentFileIcon}"
                                                   FontSize="28" VerticalOptions="Center" />
                                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding AttachmentFileName}"
                                                       TextColor="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                                       FontAttributes="Bold"
                                                       MaximumWidthRequest="260"
                                                       LineBreakMode="TailTruncation" />
                                                <Button Text="Open File"
                                                        Command="{Binding OpenFileCommand}"
                                                        BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White"
                                                        FontSize="10" CornerRadius="3"
                                                        Padding="8,2" HeightRequest="24" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <!-- Reactions row -->
                                    <FlexLayout Grid.Row="4" Grid.Column="1"
                                                BindableLayout.ItemsSource="{Binding Reactions}"
                                                IsVisible="{Binding HasReactions}"
                                                Wrap="NoWrap" Direction="Row"
                                                Margin="0,4,0,0">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ReactionCountItem">
                                                <Border Margin="0,0,4,0" Padding="6,2"
                                                        BackgroundColor="{Binding IsOwn, Converter={StaticResource ReactionBgConverter}}"
                                                        StrokeThickness="1"
                                                        Stroke="{Binding IsOwn, Converter={StaticResource ReactionStrokeConverter}}"
                                                        StrokeShape="RoundRectangle 12">
                                                    <Label Text="{Binding Display}"
                                                           FontSize="12" TextColor="{DynamicResource ThemeTextPrimary}">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>
                                    <!-- Link preview card -->
                                    <Grid Grid.Row="5" Grid.Column="1"
                                          IsVisible="{Binding Preview, Converter={StaticResource NullToBoolConverter}}"
                                          Margin="0,6,40,4" ColumnDefinitions="4,*">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenLinkCommand}" />
                                        </Grid.GestureRecognizers>
                                        <BoxView Grid.Column="0" BackgroundColor="{DynamicResource ThemeAccent}"
                                                 WidthRequest="4" CornerRadius="2" VerticalOptions="Fill" />
                                        <VerticalStackLayout Grid.Column="1" Padding="10,8" Spacing="3"
                                                             BackgroundColor="{DynamicResource ThemeBgPanel}">
                                            <Label Text="{Binding Preview.SiteName}"
                                                   TextColor="{DynamicResource ThemeAccentLight}" FontSize="10" FontAttributes="Bold"
                                                   IsVisible="{Binding Preview.SiteName, Converter={StaticResource StringToBoolConverter}}" />
                                            <Label Text="{Binding Preview.Title}"
                                                   TextColor="{DynamicResource ThemeTextPrimary}" FontSize="13" FontAttributes="Bold"
                                                   IsVisible="{Binding Preview.Title, Converter={StaticResource StringToBoolConverter}}"
                                                   MaxLines="2" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Preview.Description}"
                                                   TextColor="{DynamicResource ThemeTextSecondary}" FontSize="11"
                                                   IsVisible="{Binding Preview.Description, Converter={StaticResource StringToBoolConverter}}"
                                                   MaxLines="3" LineBreakMode="TailTruncation" />
                                            <Image Source="{Binding Preview.ImageUrl}"
                                                   IsVisible="{Binding Preview.ImageUrl, Converter={StaticResource StringToBoolConverter}}"
                                                   Aspect="AspectFill" HeightRequest="160"
                                                   HorizontalOptions="Start" WidthRequest="280" Margin="0,4,0,0" />
                                            <!-- Open / watch buttons -->
                                            <HorizontalStackLayout Spacing="8" Margin="0,6,0,2">
                                                <Button Text="🔗 Open in Browser"
                                                        Command="{Binding OpenLinkCommand}"
                                                        BackgroundColor="{DynamicResource ThemeAccent}" TextColor="{DynamicResource ThemeTextPrimary}"
                                                        FontSize="11" CornerRadius="4"
                                                        Padding="10,4" HeightRequest="28" />
                                                <Button Text="▶ Watch in App"
                                                        Command="{Binding WatchVideoCommand}"
                                                        IsVisible="{Binding IsVideoLink}"
                                                        BackgroundColor="{DynamicResource ThemeSuccess}" TextColor="{DynamicResource ThemeTextPrimary}"
                                                        FontSize="11" CornerRadius="4"
                                                        Padding="10,4" HeightRequest="28" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                    <!-- Thread reply count -->
                                    <Label Grid.Row="6" Grid.Column="1"
                                           Text="{Binding ThreadLabel}"
                                           IsVisible="{Binding HasThread}"
                                           TextColor="{DynamicResource ThemeAccentLight}" FontSize="10"
                                           HorizontalOptions="Start"
                                           Margin="0,2,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.OpenThreadCommand, Source={x:Reference RootPage}}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <!-- Read receipt -->
                                    <Label Grid.Row="6" Grid.Column="1"
                                           Text="Seen"
                                           IsVisible="{Binding ShowSeenReceipt}"
                                           TextColor="{DynamicResource ThemeAccentLight}" FontSize="10"
                                           HorizontalOptions="End"
                                           Margin="0,2,4,0" />
                                </Grid>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Load earlier messages pill (top) -->
                <Border IsVisible="{Binding HasMoreHistory}"
                        VerticalOptions="Start" HorizontalOptions="Center"
                        Margin="0,10,0,0"
                        BackgroundColor="{DynamicResource ThemeBgElevated}" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                    <Button Text="↑  Load earlier messages"
                            Command="{Binding LoadOlderMessagesCommand}"
                            BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextMuted}"
                            FontSize="11" FontAttributes="Bold"
                            Padding="16,6" HeightRequest="34" />
                </Border>

                <!-- New messages pill -->
                <Border IsVisible="{Binding HasUnreadBelow}"
                        VerticalOptions="End" HorizontalOptions="Center"
                        Margin="0,0,0,10"
                        BackgroundColor="{DynamicResource ThemeDanger}" StrokeThickness="0"
                        StrokeShape="RoundRectangle 16">
                    <Button Text="{Binding UnreadPillText}"
                            Command="{Binding ScrollToLatestCommand}"
                            BackgroundColor="Transparent" TextColor="White"
                            FontSize="11" FontAttributes="Bold"
                            Padding="16,6" HeightRequest="34" />
                </Border>

                </Grid><!-- /messages + pill wrapper -->

                <!-- Search results -->
                <CollectionView Grid.Row="4" ItemsSource="{Binding SearchResults}"
                                IsVisible="{Binding IsSearchOpen}"
                                BackgroundColor="{DynamicResource ThemeBgPrimary}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageViewItem">
                            <VerticalStackLayout Padding="14,6" Spacing="2">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding Message.AuthorUsername}"
                                           TextColor="{DynamicResource ThemeAccentLight}" FontSize="12" FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Label Text="{Binding AuthorRoleIcon}" FontSize="10" VerticalOptions="Center"
                                           IsVisible="{Binding HasAuthorRoleIcon}" />
                                    <Label FontFamily="DMMono" Text="{Binding Message.CreatedAt, Converter={StaticResource UtcToLocalTimeConverter}}"
                                           TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Message.Content}" TextColor="{DynamicResource ThemeTextPrimary}"
                                       FontSize="13" LineBreakMode="WordWrap" />
                                <BoxView HeightRequest="1" BackgroundColor="{DynamicResource ThemeBgPanel}" Margin="0,4,0,0" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="{Binding SearchEmptyText}"
                               TextColor="{DynamicResource ThemeTextMuted}" FontSize="13" FontAttributes="Italic"
                               HorizontalOptions="Center" VerticalOptions="Start"
                               Margin="0,32,0,0" />
                    </CollectionView.EmptyView>
                </CollectionView>

                <!-- Search loading spinner -->
                <ActivityIndicator Grid.Row="4" IsRunning="{Binding IsSearching}"
                                   IsVisible="{Binding IsSearching}"
                                   Color="{DynamicResource ThemeAccent}"
                                   VerticalOptions="Center" HorizontalOptions="Center" />

                <!-- Pinned messages panel -->
                <Grid Grid.Row="4" IsVisible="{Binding IsPinsOpen}" BackgroundColor="{DynamicResource ThemeBgPrimary}"
                      RowDefinitions="Auto,*">
                    <Label Grid.Row="0" Text="📌  Pinned Messages"
                           TextColor="{DynamicResource ThemeWarning}" FontSize="13" FontAttributes="Bold"
                           Padding="14,10,14,6" BackgroundColor="{DynamicResource ThemeBgElevated}" />
                    <CollectionView Grid.Row="1" ItemsSource="{Binding PinnedMessages}"
                                    BackgroundColor="{DynamicResource ThemeBgPrimary}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MessageViewItem">
                                <Grid Padding="14,8" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto"
                                      BackgroundColor="{DynamicResource ThemeBgPrimary}">
                                    <FlyoutBase.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="📌 Unpin"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UnpinMessageCommand}"
                                                CommandParameter="{Binding .}" />
                                        </MenuFlyout>
                                    </FlyoutBase.ContextFlyout>
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                                        <Label Text="{Binding Message.AuthorUsername}"
                                               TextColor="{DynamicResource ThemeAccentLight}" FontAttributes="Bold" FontSize="12" />
                                        <Label Text="{Binding AuthorRoleIcon}" FontSize="10" VerticalOptions="Center"
                                               IsVisible="{Binding HasAuthorRoleIcon}" />
                                        <Label FontFamily="DMMono" Text="{Binding Message.CreatedAt, Converter={StaticResource UtcToLocalTimeConverter}}"
                                               TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" VerticalOptions="End" />
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Message.Content}"
                                           TextColor="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                           LineBreakMode="WordWrap" MaxLines="4" />
                                    <BoxView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                             HeightRequest="1" BackgroundColor="{DynamicResource ThemeBgPanel}"
                                             VerticalOptions="End" Margin="0,8,0,0" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="No pinned messages yet."
                                   TextColor="{DynamicResource ThemeTextMuted}" FontSize="13" FontAttributes="Italic"
                                   HorizontalOptions="Center" VerticalOptions="Start"
                                   Margin="0,32,0,0" />
                        </CollectionView.EmptyView>
                    </CollectionView>
                </Grid>

                <!-- PTT hint (Voice tab only) -->
                <Label Grid.Row="5"
                       BackgroundColor="{DynamicResource ThemeBgPanel}" Padding="12,8"
                       IsVisible="{Binding IsVoiceTab}"
                       Text="{Binding VoiceHintText}"
                       TextColor="{Binding VoiceHintColor}"
                       FontSize="11" FontAttributes="Italic"
                       VerticalOptions="Center" />

                <!-- Message input area (Text, Stream, and DM) -->
                <Grid Grid.Row="5" BackgroundColor="{DynamicResource ThemeBgHeader}" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Padding="12,4,12,8"
                      IsVisible="{Binding ShowMessageInput}">
                    <!-- Reply bar -->
                    <Grid Grid.Row="0" IsVisible="{Binding IsReplying}"
                          BackgroundColor="{DynamicResource ThemeBgPanel}" Margin="-12,0,-12,4" Padding="12,5"
                          ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="↩" TextColor="{DynamicResource ThemeAccentLight}"
                               FontSize="12" VerticalOptions="Center" Margin="0,0,8,0" />
                        <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                            <Label Text="{Binding ReplyingToUsername, StringFormat='Replying to {0}'}"
                                   TextColor="{DynamicResource ThemeAccentLight}" FontSize="10" FontAttributes="Bold" />
                            <Label Text="{Binding ReplyingToPreview}"
                                   TextColor="{DynamicResource ThemeTextSecondary}" FontSize="10"
                                   LineBreakMode="TailTruncation" MaxLines="1" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="✕"
                                Command="{Binding CancelReplyCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextSecondary}"
                                FontSize="13" HeightRequest="28" WidthRequest="28" Padding="0" />
                    </Grid>
                    <!-- Live speech hypothesis -->
                    <Label Grid.Row="1"
                           Text="{Binding HypothesisText, StringFormat='🎙 {0}…'}"
                           TextColor="{DynamicResource ThemeWarning}" FontSize="11" FontAttributes="Italic"
                           Margin="0,0,0,2"
                           IsVisible="{Binding HypothesisText, Converter={StaticResource StringToBoolConverter}}" />
                    <!-- Typing indicator -->
                    <Label Grid.Row="2"
                           Text="{Binding TypingText}"
                           TextColor="{DynamicResource ThemeTextSecondary}" FontSize="10" FontAttributes="Italic"
                           Margin="0,0,0,2"
                           IsVisible="{Binding TypingText, Converter={StaticResource StringToBoolConverter}}" />
                    <!-- Slowmode cooldown indicator -->
                    <Label Grid.Row="2"
                           Text="{Binding SlowmodeCooldownLabel}"
                           TextColor="{DynamicResource ThemeWarning}" FontSize="10" FontAttributes="Bold"
                           HorizontalOptions="End" Margin="0,0,0,2"
                           IsVisible="{Binding IsCooldownActive}" />
                    <!-- Pending attachment preview -->
                    <Grid Grid.Row="3" IsVisible="{Binding HasPendingAttachment}" Padding="0,4,0,4">
                        <HorizontalStackLayout Spacing="8">
                            <!-- Image thumbnail (only when pending is an image) -->
                            <Image Source="{Binding PendingAttachmentUrl}"
                                   HeightRequest="48" WidthRequest="64"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding PendingIsImage}" />
                            <!-- File icon (only when pending is a non-image file) -->
                            <Border IsVisible="{Binding PendingIsImage, Converter={StaticResource InvertBoolConverter}}"
                                    BackgroundColor="{DynamicResource ThemeBgPanel}" StrokeThickness="1" Stroke="#292525"
                                    StrokeShape="RoundRectangle 4" Padding="8,4">
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <Label Text="📁" FontSize="20" VerticalOptions="Center" />
                                    <Label Text="{Binding PendingAttachmentFileName}"
                                           TextColor="{DynamicResource ThemeTextPrimary}" FontSize="11"
                                           VerticalOptions="Center"
                                           MaximumWidthRequest="200"
                                           LineBreakMode="TailTruncation" />
                                </HorizontalStackLayout>
                            </Border>
                            <Label Text="📎 Image attached" TextColor="{DynamicResource ThemeAccentLight}" FontSize="11"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding PendingIsImage}" />
                            <Label Text="📎 File attached" TextColor="{DynamicResource ThemeAccentLight}" FontSize="11"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding PendingIsImage, Converter={StaticResource InvertBoolConverter}}" />
                            <Button Text="✕" Command="{Binding ClearAttachmentCommand}"
                                    BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextSecondary}"
                                    FontSize="14" Padding="4,0" HeightRequest="28" WidthRequest="28" />
                        </HorizontalStackLayout>
                    </Grid>
                    <!-- Emoji picker panel -->
                    <Border Grid.Row="4" BackgroundColor="{DynamicResource ThemeBgPanel}" StrokeThickness="0" Padding="4,4,4,4"
                            IsVisible="{Binding IsEmojiPickerOpen}">
                        <ScrollView HeightRequest="108" Orientation="Vertical">
                            <FlexLayout BindableLayout.ItemsSource="{x:Static shared:EmojiData.Common}"
                                        Wrap="Wrap" Direction="Row" AlignContent="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Label Text="{Binding .}" FontSize="22"
                                               WidthRequest="40" HeightRequest="38"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.InsertEmojiCommand, Source={x:Reference RootPage}}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </ScrollView>
                    </Border>
                    <!-- GIF picker panel -->
                    <Border Grid.Row="5" BackgroundColor="{DynamicResource ThemeBgPanel}" StrokeThickness="0" Padding="4,6,4,4"
                            IsVisible="{Binding IsGifPickerOpen}">
                        <Grid RowDefinitions="Auto,*">
                            <!-- Search bar -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                                <Entry Grid.Column="0"
                                       Placeholder="Search GIFs…"
                                       Text="{Binding GifSearchQuery}"
                                       ReturnCommand="{Binding SearchGifsCommand}"
                                       BackgroundColor="{DynamicResource ThemeBgPanel}" TextColor="{DynamicResource ThemeTextPrimary}" PlaceholderColor="#4a443d" />
                                <Button Grid.Column="1" Text="Search"
                                        Command="{Binding SearchGifsCommand}"
                                        BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White" FontSize="12"
                                        HeightRequest="36" Padding="10,0" Margin="4,0,0,0" CornerRadius="3" />
                            </Grid>
                            <!-- Loading indicator -->
                            <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsSearchingGifs}"
                                               IsVisible="{Binding IsSearchingGifs}"
                                               Color="{DynamicResource ThemeAccent}" HeightRequest="120" />
                            <!-- Error / empty state -->
                            <Label Grid.Row="1"
                                   Text="{Binding GifErrorText}"
                                   TextColor="{DynamicResource ThemeWarning}" FontSize="11"
                                   Margin="4,8"
                                   IsVisible="{Binding GifErrorText, Converter={StaticResource StringToBoolConverter}}" />
                            <!-- GIF grid -->
                            <CollectionView Grid.Row="1" ItemsSource="{Binding GifResults}"
                                            HeightRequest="200"
                                            IsVisible="{Binding IsSearchingGifs, Converter={StaticResource InvertBoolConverter}}">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical" Span="4"
                                                     HorizontalItemSpacing="3" VerticalItemSpacing="3" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="svc:GifResult">
                                        <Image Source="{Binding PreviewUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="72"
                                               BackgroundColor="{DynamicResource ThemeBgPanel}">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.SendGifCommand, Source={x:Reference RootPage}}"
                                                    CommandParameter="{Binding .}" />
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Grid>
                    </Border>
                    <!-- Input row -->
                    <Grid Grid.Row="6" ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                        <Button Grid.Column="0" Text="😊"
                                Command="{Binding ToggleEmojiPickerCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextSecondary}"
                                FontSize="16" HeightRequest="36" WidthRequest="40" Padding="0" Margin="0,0,2,0"
                                ToolTipProperties.Text="Emoji picker" />
                        <Button Grid.Column="1" Text="📎"
                                Command="{Binding PickAttachmentCommand}"
                                BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextSecondary}" FontSize="16"
                                HeightRequest="36" WidthRequest="40" Padding="0" Margin="0,0,2,0"
                                ToolTipProperties.Text="Attach an image" />
                        <Button Grid.Column="2" Text="GIF"
                                Command="{Binding ToggleGifPickerCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{Binding IsGifPickerOpen, Converter={StaticResource ActiveButtonTextColorConverter}}"
                                FontSize="11" FontAttributes="Bold"
                                HeightRequest="36" WidthRequest="40" Padding="0" Margin="0,0,4,0"
                                ToolTipProperties.Text="GIF picker" />
                        <Entry Grid.Column="3"
                               Placeholder="{Binding MessagePlaceholderText}"
                               BackgroundColor="{DynamicResource ThemeBgPrimary}" PlaceholderColor="#4a443d" TextColor="{DynamicResource ThemeTextPrimary}"
                               Text="{Binding MessageInput}" ReturnCommand="{Binding SendMessageCommand}" />
                        <Button Grid.Column="4" Text="Send" Command="{Binding SendMessageCommand}"
                                BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White" CornerRadius="3"
                                FontSize="12" Margin="8,0,0,0" HeightRequest="36" Padding="14,0"
                                IsEnabled="{Binding IsCooldownActive, Converter={StaticResource InvertBoolConverter}}" />
                    </Grid>
                </Grid>

                <!-- Typing row shown on Stream tab too (always visible below messages) -->
                <Label Grid.Row="6"
                       Text="{Binding TypingText}"
                       BackgroundColor="{DynamicResource ThemeBgHeader}"
                       TextColor="{DynamicResource ThemeTextSecondary}" FontSize="10" FontAttributes="Italic"
                       Padding="14,4"
                       IsVisible="{Binding IsStreamTab, Converter={StaticResource InvertBoolConverter}}" />

            </Grid>

            <!-- ═══ THREAD PANEL ═══ -->
            <Grid Grid.Column="2" BackgroundColor="{DynamicResource ThemeBgPanel}" WidthRequest="320"
                  IsVisible="{Binding IsThreadOpen}"
                  RowDefinitions="Auto,*,Auto">
                <!-- Thread header -->
                <Grid Grid.Row="0" BackgroundColor="{DynamicResource ThemeBgElevated}" Padding="12,8" ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="🧵 Thread" TextColor="{DynamicResource ThemeTextPrimary}"
                           FontAttributes="Bold" FontSize="13" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="✕" Command="{Binding CloseThreadCommand}"
                            BackgroundColor="Transparent" TextColor="{DynamicResource ThemeTextSecondary}"
                            FontSize="13" WidthRequest="28" HeightRequest="28" Padding="0" />
                </Grid>
                <!-- Thread messages -->
                <CollectionView Grid.Row="1" ItemsSource="{Binding ThreadMessages}"
                                BackgroundColor="Transparent">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageViewItem">
                            <Grid Padding="12,6" ColumnDefinitions="Auto,*"
                                  IsVisible="{Binding IsRegularMessage}">
                                <Frame Grid.Column="0" CornerRadius="14" WidthRequest="28" HeightRequest="28"
                                       BackgroundColor="{DynamicResource ThemeAccent}" Padding="0" Margin="0,0,8,0"
                                       VerticalOptions="Start">
                                    <Label Text="{Binding Message.AuthorUsername, Converter={StaticResource InitialsConverter}}"
                                           TextColor="White" FontSize="10" FontAttributes="Bold"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding Message.AuthorUsername}"
                                               TextColor="{DynamicResource ThemeAccentLight}" FontAttributes="Bold" FontSize="12" />
                                        <Label Text="{Binding AuthorRoleIcon}" FontSize="10" VerticalOptions="Center"
                                               IsVisible="{Binding HasAuthorRoleIcon}" />
                                        <Label FontFamily="DMMono" Text="{Binding Message.CreatedAt, Converter={StaticResource UtcToLocalTimeConverter}}"
                                               TextColor="{DynamicResource ThemeTextMuted}" FontSize="10" VerticalOptions="End" Margin="0,0,0,1" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Message.Content}" TextColor="{DynamicResource ThemeTextPrimary}" FontSize="12"
                                           LineBreakMode="WordWrap"
                                           IsVisible="{Binding IsDeleted, Converter={StaticResource InvertBoolConverter}}" />
                                    <Label Text="✗  This message was deleted." TextColor="{DynamicResource ThemeTextMuted}"
                                           FontSize="11" FontAttributes="Italic"
                                           IsVisible="{Binding IsDeleted}" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <!-- Thread reply input -->
                <Grid Grid.Row="2" BackgroundColor="{DynamicResource ThemeBgHeader}" Padding="8,6" ColumnDefinitions="*,Auto">
                    <Entry Grid.Column="0" Placeholder="Reply in thread…"
                           BackgroundColor="{DynamicResource ThemeBgPrimary}" PlaceholderColor="#4a443d" TextColor="{DynamicResource ThemeTextPrimary}"
                           Text="{Binding ThreadInput}"
                           ReturnCommand="{Binding SendThreadMessageCommand}" />
                    <Button Grid.Column="1" Text="Send" Command="{Binding SendThreadMessageCommand}"
                            BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White" CornerRadius="3"
                            FontSize="12" Margin="6,0,0,0" HeightRequest="36" Padding="12,0" />
                </Grid>
            </Grid>

        </Grid>

        <!-- ═══ BOTTOM CONTROLS BAR ═══ -->
        <Grid Grid.Row="4" BackgroundColor="{DynamicResource ThemeBgHeader}" Padding="10,6"
              ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">

            <Button Grid.Column="0"
                    Text="{Binding IsMuted, Converter={StaticResource MuteButtonConverter}}"
                    Command="{Binding ToggleMuteCommand}"
                    BackgroundColor="{Binding IsMuted, Converter={StaticResource MutedBgConverter}}"
                    TextColor="White" FontSize="13"
                    WidthRequest="40" HeightRequest="32" CornerRadius="3" Margin="0,0,4,0"
                    ToolTipProperties.Text="Mute / Unmute your microphone" />

            <Button Grid.Column="1"
                    Text="{Binding IsDeafened, Converter={StaticResource DeafenButtonConverter}}"
                    Command="{Binding ToggleDeafenCommand}"
                    BackgroundColor="{DynamicResource ThemeBgElevated}" TextColor="White" FontSize="13"
                    WidthRequest="40" HeightRequest="32" CornerRadius="3" Margin="0,0,4,0"
                    ToolTipProperties.Text="Deafen / Undeafen" />

            <Button Grid.Column="2"
                    Text="🔁 Mic Test"
                    Command="{Binding ToggleMicLoopbackCommand}"
                    BackgroundColor="{Binding IsLoopbackActive, Converter={StaticResource LoopbackColorConverter}}"
                    TextColor="White" FontSize="11"
                    HeightRequest="32" CornerRadius="3" Margin="0,0,8,0" Padding="8,0"
                    ToolTipProperties.Text="Play your mic back to yourself to test audio" />

            <VerticalStackLayout Grid.Column="3" VerticalOptions="Center" Spacing="1" Margin="0,0,8,0">
                <Label Text="MIC" TextColor="{DynamicResource ThemeTextMuted}" FontSize="8" HorizontalOptions="Center" />
                <ProgressBar Progress="{Binding MicLevel}"
                             ProgressColor="{Binding MicLevel, Converter={StaticResource MicLevelColorConverter}}"
                             WidthRequest="80" HeightRequest="10" BackgroundColor="{DynamicResource ThemeBgPrimary}" />
            </VerticalStackLayout>

            <Button Grid.Column="4"
                    Text="{Binding PttButtonLabel}"
                    Command="{Binding SetPttKeyCommand}"
                    BackgroundColor="{Binding PttButtonColor}"
                    TextColor="White" FontSize="11"
                    HeightRequest="32" CornerRadius="3" Margin="0,0,8,0" Padding="10,0"
                    ToolTipProperties.Text="Hold your Push to Talk key to transmit. Click here to rebind." />

            <Button Grid.Column="5"
                    Text="{Binding StreamButtonLabel}"
                    Command="{Binding ToggleStreamCommand}"
                    BackgroundColor="{Binding StreamButtonColor}"
                    TextColor="White" FontSize="11"
                    HeightRequest="32" CornerRadius="3" Margin="0,0,4,0" Padding="10,0"
                    ToolTipProperties.Text="Share your screen with everyone in the channel" />

            <Button Grid.Column="6"
                    Text="{Binding CameraButtonLabel}"
                    Command="{Binding ToggleCameraCommand}"
                    BackgroundColor="{Binding CameraButtonColor}"
                    TextColor="White" FontSize="11"
                    HeightRequest="32" CornerRadius="3" Margin="0,0,8,0" Padding="10,0"
                    ToolTipProperties.Text="Toggle webcam video in voice channel" />

            <HorizontalStackLayout Grid.Column="7" Spacing="6" VerticalOptions="Center" Margin="8,0">
                <Ellipse WidthRequest="8" HeightRequest="8" Fill="#36b864"
                         IsVisible="{Binding SelectedChannel, Converter={StaticResource NullToBoolConverter}}"
                         VerticalOptions="Center" />
                <Label Text="{Binding SelectedChannel.Name, StringFormat='🎙 {0}', FallbackValue='No channel'}"
                       TextColor="{DynamicResource ThemeTextSecondary}" FontSize="11" VerticalOptions="Center" />
                <Label Text="● LOOPBACK" TextColor="{DynamicResource ThemeWarning}" FontSize="10" FontAttributes="Bold"
                       VerticalOptions="Center" IsVisible="{Binding IsLoopbackActive}" />
            </HorizontalStackLayout>

            <Label Grid.Column="8" Text="{Binding CurrentServerUrl}" TextColor="{DynamicResource ThemeTextMuted}"
                   FontSize="10" VerticalOptions="Center" Margin="0,0,12,0" />

            <Button Grid.Column="9" Text="⚙"
                    Command="{Binding OpenSettingsCommand}"
                    BackgroundColor="{DynamicResource ThemeBgElevated}" TextColor="{DynamicResource ThemeTextSecondary}" FontSize="14"
                    WidthRequest="36" HeightRequest="32" CornerRadius="3" Margin="0,0,4,0"
                    ToolTipProperties.Text="Settings" />

            <Button Grid.Column="10" Text="Sign Out"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="{DynamicResource ThemeBgElevated}" TextColor="{DynamicResource ThemeDanger}"
                    FontSize="11" FontAttributes="Bold"
                    HeightRequest="32" CornerRadius="3" Padding="10,0" />
        </Grid>

        <!-- ═══ VERSION SYNC OVERLAY (blocking; covers the whole page) ═══ -->
        <Grid Grid.RowSpan="5" IsVisible="{Binding VersionSyncInProgress}"
              BackgroundColor="#cc0a0909">
            <Border Stroke="#292525" StrokeThickness="1" BackgroundColor="{DynamicResource ThemeBgElevated}"
                    Padding="28,22" WidthRequest="360"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Spacing="14">
                    <Label Text="{Binding VersionSyncTitle}" TextColor="{DynamicResource ThemeTextPrimary}"
                           FontAttributes="Bold" FontSize="15" HorizontalOptions="Center" />
                    <ProgressBar Progress="{Binding VersionSyncProgress}" ProgressColor="#f04010" />
                    <Label Text="{Binding VersionSyncStage}" TextColor="{DynamicResource ThemeTextSecondary}"
                           FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
