<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FatGuysSpeak.Client.Pages.RegisterPage"
             Title="Create Account"
             BackgroundColor="{DynamicResource ThemeBgInput}">

    <ScrollView>
        <VerticalStackLayout Padding="40" Spacing="16" VerticalOptions="Center">

            <Image Source="fgs_logo.png" WidthRequest="104" HeightRequest="104" HorizontalOptions="Center" Margin="0,0,0,4" />
            <Label Text="Create an account" FontSize="24" FontAttributes="Bold"
                   TextColor="{DynamicResource ThemeTextPrimary}" HorizontalOptions="Center" />

            <Label Text="USERNAME" FontSize="12" TextColor="{DynamicResource ThemeTextSecondary}" FontAttributes="Bold" />
            <Entry Placeholder="Choose a username" PlaceholderColor="{DynamicResource ThemeTextMuted}"
                   TextColor="White" BackgroundColor="{DynamicResource ThemeBgInput}" Text="{Binding Username}" />

            <Label Text="PASSWORD" FontSize="12" TextColor="{DynamicResource ThemeTextSecondary}" FontAttributes="Bold" />
            <Entry Placeholder="Choose a password" PlaceholderColor="{DynamicResource ThemeTextMuted}"
                   TextColor="White" BackgroundColor="{DynamicResource ThemeBgInput}"
                   IsPassword="True" Text="{Binding Password}" />

            <Label Text="SERVER" FontSize="10" TextColor="{DynamicResource ThemeTextMuted}"
                   FontAttributes="Bold" Margin="0,8,0,0" />
            <Picker ItemsSource="{Binding ServerPickerItems}"
                    SelectedItem="{Binding SelectedServerOption, Mode=TwoWay}"
                    IsVisible="{Binding HasSavedServers}"
                    Title="Select or add a server..." TitleColor="{DynamicResource ThemeTextMuted}"
                    TextColor="{DynamicResource ThemeTextMuted}" BackgroundColor="{DynamicResource ThemeBgInput}" />
            <Entry Placeholder="http://localhost:5238"
                   Text="{Binding ServerUrl}"
                   IsVisible="{Binding IsEnteringNewServer}"
                   TextColor="{DynamicResource ThemeTextMuted}" BackgroundColor="{DynamicResource ThemeBgInput}"
                   PlaceholderColor="{DynamicResource ThemeTextMuted}" FontSize="12" />

            <Label Text="{Binding ErrorMessage}" TextColor="{DynamicResource ThemeDanger}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

            <Button Text="Continue" Command="{Binding RegisterCommand}"
                    BackgroundColor="{DynamicResource ThemeAccent}" TextColor="White"
                    CornerRadius="4" HeightRequest="44" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Already have an account?" TextColor="{DynamicResource ThemeTextSecondary}" />
                <Label Text="Log In" TextColor="{DynamicResource ThemeAccentLight}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
